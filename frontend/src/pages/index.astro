---
import ShopLayout from '../layouts/ShopLayout.astro';
import BenefitsBar from '../components/shared/BenefitsBar.astro';
---

<ShopLayout title="Mediantem — Diseño que se pone">
  <BenefitsBar />

  <!-- HERO Section (placeholder - full content in Stage 2) -->
  <section class="min-h-[calc(100vh-94px)] flex items-center px-8 relative overflow-hidden">
    <!-- Background glow -->
    <div class="absolute -top-[150px] -right-[100px] w-[550px] h-[550px] rounded-full bg-[radial-gradient(circle,rgba(233,69,96,.16)_0%,transparent_65%)] pointer-events-none"></div>

    <div class="max-w-[1200px] w-full mx-auto grid grid-cols-1 lg:grid-cols-[1fr_420px] gap-16 items-center relative z-[1]">
      <!-- Left -->
      <div>
        <h1 class="font-display text-[clamp(2.2rem,4.5vw,3.5rem)] font-black leading-[1.08] mb-4 text-white">
          Experience comfort and<br/>
          style with our <span class="text-brand-rojo">premium</span>
        </h1>
        <p class="text-[.92rem] text-white/50 mb-8 max-w-[380px]">
          Choose from a variety of colors and patterns
        </p>

        <div class="flex gap-4 flex-wrap mb-12">
          <a href="/shop" class="inline-flex items-center justify-center bg-brand-rojo text-white font-display text-[.82rem] font-bold tracking-[.04em] py-3 px-7 border-2 border-brand-rojo rounded-md hover:bg-brand-rojo-dark hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(233,69,96,.35)] transition-all">
            Add to Cart
          </a>
          <a href="/about" class="inline-flex items-center justify-center bg-transparent text-white font-display text-[.82rem] font-semibold tracking-[.04em] py-3 px-7 border-2 border-white/30 rounded-md hover:border-white/70 hover:bg-white/[.06] transition-all">
            Gift Options
          </a>
        </div>

        <!-- Stats -->
        <div class="flex items-center gap-8 pt-8 border-t border-white/10">
          <div class="flex flex-col">
            <span class="font-display text-3xl font-black text-white leading-none">100<sup class="text-base">+</sup></span>
            <span class="text-[.73rem] text-white/[.42] mt-0.5">Styles</span>
          </div>
          <div class="w-px h-[34px] bg-white/10"></div>
          <div class="flex flex-col">
            <span class="font-display text-3xl font-black text-white leading-none">50<sup class="text-base">+</sup></span>
            <span class="text-[.73rem] text-white/[.42] mt-0.5">Colors</span>
          </div>
          <div class="w-px h-[34px] bg-white/10"></div>
          <div class="flex flex-col">
            <span class="font-display text-3xl font-black text-white leading-none">1,000<sup class="text-base">+</sup></span>
            <span class="text-[.73rem] text-white/[.42] mt-0.5">Happy customers</span>
          </div>
        </div>
      </div>

      <!-- Right: Product image + Offer Card -->
      <div class="hidden lg:flex flex-col gap-4">
        <!-- Product image placeholder -->
        <div class="rounded-[10px] overflow-hidden border border-white/10 aspect-[4/3] bg-brand-azul flex items-center justify-center">
          <svg viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
            <rect width="400" height="300" fill="#16213E"/>
            <line x1="0" y1="0" x2="400" y2="300" stroke="#E94560" stroke-width="1.5" opacity=".25"/>
            <line x1="400" y1="0" x2="0" y2="300" stroke="#E94560" stroke-width="1.5" opacity=".25"/>
            <rect x="140" y="90" width="120" height="120" rx="8" stroke="#E94560" stroke-width="1.5" opacity=".3" fill="none"/>
            <text x="50%" y="88%" dominant-baseline="middle" text-anchor="middle" font-family="Montserrat,sans-serif" font-size="11" fill="rgba(255,255,255,0.2)" font-weight="700" letter-spacing="2">foto del producto</text>
          </svg>
        </div>

        <!-- Offer Card -->
        <div class="bg-white/5 border border-white/10 rounded-[10px] p-5 backdrop-blur-lg">
          <div class="flex items-start justify-between mb-4">
            <div class="font-display text-[.85rem] font-black text-white">
              Limited
              <small class="block text-[.65rem] font-semibold opacity-65">Only</small>
            </div>
            <div class="text-right">
              <span class="font-display text-[.62rem] font-semibold text-white/40 uppercase tracking-[.1em] block mb-0.5">Time left</span>
              <div class="font-display text-xl font-black text-brand-rojo">
                <span id="cdH">04</span>h <span id="cdM">30</span>m <span id="cdS">45</span>s
              </div>
            </div>
          </div>
          <div class="flex gap-2.5">
            <a href="/shop" class="flex-1 text-center bg-brand-rojo text-white font-display text-[.77rem] font-bold py-2.5 rounded-md hover:bg-brand-rojo-dark transition-colors">
              Buy Now
            </a>
            <a href="/about" class="flex-1 text-center font-display text-[.77rem] font-semibold text-white/65 py-2.5 border border-white/20 rounded-md hover:border-white/50 transition-colors">
              Learn More
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INFLUENCERS Section -->
  <section class="py-20 px-8 bg-brand-azul">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="font-display text-base font-bold text-white/60 mb-8">What our customers say</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <!-- Placeholder cards — will be data-driven in Stage 2 -->
        <div class="bg-white/[.04] border border-white/10 rounded-[10px] overflow-hidden hover:border-brand-rojo/35 hover:-translate-y-1 transition-all">
          <div class="aspect-[4/3] bg-brand-negro flex items-center justify-center">
            <div class="w-full h-full bg-gradient-to-br from-brand-rojo/10 to-brand-azul/70"></div>
          </div>
          <div class="p-4">
            <div class="flex items-center gap-2.5 mb-3">
              <div class="w-[34px] h-[34px] rounded-full bg-brand-rojo/15 border-2 border-brand-rojo/30 flex items-center justify-center font-display text-[.6rem] font-extrabold text-brand-rojo">AJ</div>
              <div>
                <div class="font-display text-[.8rem] font-bold text-white">Alice Johnson</div>
                <div class="text-[.7rem] text-white/[.38]">@SockLover</div>
              </div>
            </div>
            <div class="text-[.7rem] text-white/[.42] mb-3">Amazing quality · 5 stars</div>
            <a href="#" class="block text-center bg-brand-rojo text-white font-display text-[.7rem] font-bold tracking-[.05em] uppercase py-2 rounded-[5px] hover:bg-brand-rojo-dark transition-colors">Follow Us</a>
          </div>
        </div>

        <div class="bg-white/[.04] border border-white/10 rounded-[10px] overflow-hidden hover:border-brand-rojo/35 hover:-translate-y-1 transition-all">
          <div class="aspect-[4/3] bg-brand-negro flex items-center justify-center">
            <div class="w-full h-full bg-gradient-to-br from-brand-rojo/10 to-brand-azul/70"></div>
          </div>
          <div class="p-4">
            <div class="flex items-center gap-2.5 mb-3">
              <div class="w-[34px] h-[34px] rounded-full bg-brand-rojo/15 border-2 border-brand-rojo/30 flex items-center justify-center font-display text-[.6rem] font-extrabold text-brand-rojo">MT</div>
              <div>
                <div class="font-display text-[.8rem] font-bold text-white">Mark Thompson</div>
                <div class="text-[.7rem] text-white/[.38]">@SockEnthusiast</div>
              </div>
            </div>
            <div class="text-[.7rem] text-white/[.42] mb-3">Best socks ever! · 4½ stars</div>
            <a href="/shop" class="block text-center bg-brand-rojo text-white font-display text-[.7rem] font-bold tracking-[.05em] uppercase py-2 rounded-[5px] hover:bg-brand-rojo-dark transition-colors">Shop Now</a>
          </div>
        </div>

        <div class="bg-white/[.04] border border-white/10 rounded-[10px] overflow-hidden hover:border-brand-rojo/35 hover:-translate-y-1 transition-all">
          <div class="aspect-[4/3] bg-brand-negro flex items-center justify-center">
            <div class="w-full h-full bg-gradient-to-br from-brand-rojo/10 to-brand-azul/70"></div>
          </div>
          <div class="p-4">
            <div class="flex items-center gap-2.5 mb-3">
              <div class="w-[34px] h-[34px] rounded-full bg-brand-rojo/15 border-2 border-brand-rojo/30 flex items-center justify-center font-display text-[.6rem] font-extrabold text-brand-rojo">AJ</div>
              <div>
                <div class="font-display text-[.8rem] font-bold text-white">Alex Johnson</div>
                <div class="text-[.7rem] text-white/[.38]">@SockFan421</div>
              </div>
            </div>
            <div class="text-[.7rem] text-white/[.42] mb-3">Testimonials · Happy 5,000+</div>
            <a href="/shop" class="block text-center bg-brand-rojo text-white font-display text-[.7rem] font-bold tracking-[.05em] uppercase py-2 rounded-[5px] hover:bg-brand-rojo-dark transition-colors">Buy Now</a>
          </div>
        </div>

        <div class="bg-white/[.04] border border-white/10 rounded-[10px] overflow-hidden hover:border-brand-rojo/35 hover:-translate-y-1 transition-all">
          <div class="aspect-[4/3] bg-brand-negro flex items-center justify-center">
            <div class="w-full h-full bg-gradient-to-br from-brand-rojo/10 to-brand-azul/70"></div>
          </div>
          <div class="p-4">
            <div class="flex items-center gap-2.5 mb-3">
              <div class="w-[34px] h-[34px] rounded-full bg-brand-rojo/15 border-2 border-brand-rojo/30 flex items-center justify-center font-display text-[.6rem] font-extrabold text-brand-rojo">JL</div>
              <div>
                <div class="font-display text-[.8rem] font-bold text-white">Jamie Lee</div>
                <div class="text-[.7rem] text-white/[.38]">@SocksForLife</div>
              </div>
            </div>
            <div class="text-[.7rem] text-white/[.42] mb-3">Collections · Followers 42,845</div>
            <a href="#" class="block text-center bg-brand-rojo text-white font-display text-[.7rem] font-bold tracking-[.05em] uppercase py-2 rounded-[5px] hover:bg-brand-rojo-dark transition-colors">Get Yours</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER Section -->
  <section class="py-20 px-8 bg-brand-negro">
    <div class="max-w-[1100px] mx-auto grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-16 items-center">
      <!-- Image placeholder -->
      <div class="hidden lg:block rounded-[10px] overflow-hidden border border-white/10 aspect-[3/4] bg-brand-azul">
        <svg viewBox="0 0 300 400" fill="none" class="w-full h-full">
          <rect width="300" height="400" fill="#16213E"/>
          <line x1="0" y1="0" x2="300" y2="400" stroke="#E94560" stroke-width="1.5" opacity=".2"/>
          <line x1="300" y1="0" x2="0" y2="400" stroke="#E94560" stroke-width="1.5" opacity=".2"/>
        </svg>
      </div>
      <!-- Content -->
      <div>
        <h2 class="font-display text-[clamp(1.4rem,2.5vw,1.9rem)] font-black leading-[1.2] text-white mb-8">
          Experience the ultimate comfort and style with our premium socks. Limited-time offer available!
        </h2>
        <form id="nlForm">
          <div class="flex gap-3 mb-2.5 flex-col sm:flex-row">
            <input
              type="email"
              id="nlEmail"
              placeholder="Enter your e-mail here"
              required
              class="flex-1 bg-white/[.07] border border-white/15 rounded-md py-3 px-4 text-white font-body text-[.88rem] outline-none focus:border-brand-rojo transition-colors placeholder:text-white/30"
            />
            <button
              type="submit"
              class="bg-brand-rojo text-white font-display text-[.82rem] font-bold tracking-[.04em] py-3 px-7 border-2 border-brand-rojo rounded-md hover:bg-brand-rojo-dark transition-all"
            >
              Subscribe
            </button>
          </div>
          <p class="text-[.7rem] text-white/[.28]">No spam. Unsubscribe any time.</p>
        </form>
      </div>
    </div>
  </section>
</ShopLayout>

<script>
  // Countdown Timer
  function startCountdown() {
    let totalSeconds = 4 * 3600 + 30 * 60 + 45;
    const hEl = document.getElementById('cdH');
    const mEl = document.getElementById('cdM');
    const sEl = document.getElementById('cdS');

    setInterval(() => {
      if (totalSeconds <= 0) return;
      totalSeconds--;
      const h = Math.floor(totalSeconds / 3600);
      const m = Math.floor((totalSeconds % 3600) / 60);
      const s = totalSeconds % 60;
      if (hEl) hEl.textContent = String(h).padStart(2, '0');
      if (mEl) mEl.textContent = String(m).padStart(2, '0');
      if (sEl) sEl.textContent = String(s).padStart(2, '0');
    }, 1000);
  }
  startCountdown();

  // Newsletter form
  document.getElementById('nlForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('¡Gracias por suscribirte!');
  });
</script>
