---
/**
 * Navbar — Logo Mediantem a la izquierda, links de navegación centro,
 * CartButton + AuthButton a la derecha. Menú hamburguesa en mobile.
 */
---

<nav
  class="fixed top-0 left-0 right-0 z-[200] bg-brand-negro/[.92] backdrop-blur-[14px] border-b border-white/10 transition-colors"
  id="navbar"
>
  <div class="max-w-[1200px] mx-auto px-8 flex items-center h-[60px] gap-6">
    <!-- Logo -->
    <a href="/" class="font-display text-base font-black tracking-wide text-white whitespace-nowrap flex-shrink-0">
      Mediantem
    </a>

    <!-- Nav Center Links -->
    <div class="hidden md:flex gap-8 mx-auto">
      <a href="/" class="font-display text-[.73rem] font-semibold tracking-[.08em] uppercase text-white/60 hover:text-white transition-colors">
        Home
      </a>
      <a href="/shop" class="font-display text-[.73rem] font-semibold tracking-[.08em] uppercase text-white/60 hover:text-white transition-colors">
        Shop
      </a>
      <a href="/about" class="font-display text-[.73rem] font-semibold tracking-[.08em] uppercase text-white/60 hover:text-white transition-colors">
        About
      </a>
      <a href="/forum" class="font-display text-[.73rem] font-semibold tracking-[.08em] uppercase text-white/60 hover:text-white transition-colors">
        Community
      </a>
    </div>

    <!-- Nav End -->
    <div class="hidden md:flex gap-3 items-center ml-auto">
      <a
        href="#"
        class="font-display text-[.72rem] font-bold text-white py-[.42rem] px-4 border-2 border-white/30 rounded-[5px] hover:border-white/70 transition-colors"
        id="auth-button"
      >
        Login
      </a>
      <!-- Cart button placeholder - React island in Stage 2 -->
      <a href="/cart" class="text-lg text-white/75 hover:text-white transition-colors">
        🛒
      </a>
    </div>

    <!-- Hamburger Mobile -->
    <button class="flex md:hidden flex-col gap-[5px] p-1 ml-auto" id="hamburger">
      <span class="block w-[22px] h-[2px] bg-white transition-transform"></span>
      <span class="block w-[22px] h-[2px] bg-white transition-opacity"></span>
      <span class="block w-[22px] h-[2px] bg-white transition-transform"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div
    class="hidden flex-col bg-brand-azul px-8 pb-6 border-b border-white/10"
    id="mobileMenu"
  >
    <a href="/" class="font-display text-[.85rem] font-semibold text-white/70 py-3 border-b border-white/[.06]">Home</a>
    <a href="/shop" class="font-display text-[.85rem] font-semibold text-white/70 py-3 border-b border-white/[.06]">Shop</a>
    <a href="/about" class="font-display text-[.85rem] font-semibold text-white/70 py-3 border-b border-white/[.06]">About</a>
    <a href="/forum" class="font-display text-[.85rem] font-semibold text-white/70 py-3">Community</a>
  </div>
</nav>

<script>
  // Hamburger toggle
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');

  hamburger?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    mobileMenu?.classList.toggle('flex');
    hamburger.classList.toggle('open');
  });

  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('bg-brand-negro/[.99]');
    } else {
      navbar?.classList.remove('bg-brand-negro/[.99]');
    }
  });
</script>
